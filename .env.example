# Copy this file to .env and fill it in.   cp .env.example .env
# .env is gitignored. NEVER commit a real token — this repo learned that the hard way.
#
# docker compose auto-loads ./.env and passes it to the container via `env_file`.

# ── Required ──────────────────────────────────────────────────────────────────
# Discord Developer Portal -> your application -> Bot -> Reset Token.
# Shown exactly once. If you lose it, reset it again — it cannot be re-read.
DISCORD_TOKEN=

# Developer Portal -> your application -> General Information -> Application ID.
# This is public information (it's in your bot's invite URL); it is not a secret.
DISCORD_CLIENT_ID=

# ── Development ───────────────────────────────────────────────────────────────
# SET this while developing: commands register to this one server and appear
# INSTANTLY. Get it by right-clicking the server (with Developer Mode on) ->
# Copy Server ID.
#
# LEAVE IT EMPTY in production: commands then register globally, to every server
# the bot is in.
#
# Registration scope is chosen by whether this is set — see scripts/register.ts.
DISCORD_GUILD_ID=

# ── Optional ──────────────────────────────────────────────────────────────────
# Chance that /swog fails for comedy: "Swog unsuccessful. Please swog harder."
# Default 0.05. Set to 1 to force the failure branch when testing.
SWOG_FAIL_CHANCE=

# debug | info | warn | error   (default: info)
LOG_LEVEL=

# Where the SQLite database lives. The container sets this to /data/swog.db (a
# named volume) and you should not need to change it. Locally it defaults to
# ./data/swog.db.
DATABASE_FILE=

# ── Deployment (used by scripts/deploy.sh — not by the bot itself) ─────────────
# The server you deploy to. An ssh alias from ~/.ssh/config works and is tidier
# than a raw host: deploy.sh just runs `ssh $DEPLOY_HOST`.
DEPLOY_HOST=your-server-or-ssh-alias

# The git checkout on that server. deploy.sh pulls here and runs docker compose.
DEPLOY_PATH=/home/youruser/swog-bot

DEPLOY_BRANCH=main
